{
  "mcpServers": {
    "klayout": {
      "command": "uvx",
      "args": ["klayout-mcp"],
      "env": {
        "KLAYOUT_MCP_ALLOWED_LAYOUT_ROOTS": "/ABS/PATH/TO/layouts",
        "KLAYOUT_MCP_ALLOWED_DRC_ROOTS": "/ABS/PATH/TO/drc-decks",
        "KLAYOUT_BIN": "/Applications/klayout.app/Contents/MacOS/klayout"
      }
    }
  }
}
